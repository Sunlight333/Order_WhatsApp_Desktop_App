{
  "name": "order-whatsapp-desktop-app",
  "version": "1.0.0",
  "description": "Order Management Desktop Application with WhatsApp Integration",
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:electron": "wait-on http://localhost:5173 http://localhost:3000/api/v1/health && cross-env NODE_ENV=development electron .",
    "build": "npm run build:backend && npm run build:frontend && npm run build:electron-src && npm run build:electron:all",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "build:electron-src": "cd electron && npx tsc",
    "prebuild:electron": "node -e \"const fs=require('fs'),path=require('path');function delDB(dir){try{const files=fs.readdirSync(dir);files.forEach(f=>{const p=path.join(dir,f);const stat=fs.statSync(p);if(stat.isDirectory())delDB(p);else if(/database\\\\.db/.test(f))try{fs.unlinkSync(p);console.log('Deleted:',p)}catch(e){}})}catch(e){}};['node_modules','backend/prisma','build-electron'].forEach(d=>{if(fs.existsSync(d))delDB(d)});\" && node scripts/generate-icon.js",
    "build:electron": "electron-builder",
    "build:electron:dir": "electron-builder --dir",
    "build:electron:setup": "electron-builder --win nsis",
    "build:electron:zip": "electron-builder --win zip",
    "build:electron:all": "electron-builder --win nsis zip",
    "clear-icon-cache": "powershell -ExecutionPolicy Bypass -File scripts/clear-windows-icon-cache.ps1",
    "prisma:generate": "cd backend && npx prisma generate",
    "prisma:migrate": "cd backend && npx prisma migrate dev",
    "prisma:studio": "cd backend && npx prisma studio"
  },
  "keywords": [
    "order-management",
    "desktop-app",
    "electron",
    "whatsapp"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "tsx": "^4.7.0",
    "wait-on": "^7.2.0"
  },
  "workspaces": [
    "backend",
    "frontend",
    "shared"
  ],
  "build": {
    "appId": "com.orderwhatsapp.desktop",
    "productName": "Order WhatsApp Desktop",
    "directories": {
      "output": "build-electron",
      "buildResources": "build"
    },
    "files": [
      "electron/dist/**/*",
      "frontend/dist/**/*",
      "backend/dist/**/*",
      "backend/prisma/**/*",
      "!backend/prisma/**/*.db*",
      "!backend/prisma/**/*.db-journal",
      "!backend/prisma/**/*.db-shm",
      "!backend/prisma/**/*.db-wal",
      "!**/node_modules/**/prisma/**/*.db*",
      "!**/node_modules/**/prisma/**/*.db-shm",
      "!**/node_modules/**/prisma/**/*.db-wal",
      "!**/node_modules/**/prisma/**/*.db-journal",
      "!**/node_modules/**/order-app-backend/prisma/**/*.db*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules",
        "to": "node_modules",
        "filter": [
          "**/*",
          "!**/*.db*",
          "!**/*.db-shm",
          "!**/*.db-wal",
          "!**/*.db-journal",
          "!**/prisma/**",
          "!**/order-app-backend/prisma/**"
        ]
      },
      {
        "from": "frontend/public/assets/images/logo.png",
        "to": "assets/images/logo.png"
      }
    ],
    "asarUnpack": [
      "backend/dist/**",
      "backend/prisma/**"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.business"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": ["AppImage", "deb"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer-password.nsh"
    },
    "beforePack": "scripts/beforePack.js",
    "afterPack": "scripts/afterPack.js",
    "afterSign": "scripts/afterSign.js"
  }
}

